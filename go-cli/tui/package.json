{
  "name": "go-cli-tui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "go-cli": "bin/go-cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node bin/go-cli.js",
    "dev": "tsc --watch",
    "install-engine": "cd .. && go build -o tui/engine/go-cli ./cmd/go-cli/",
    "setup": "npm install && npm run build && npm run install-engine"
  },
  "dependencies": {
    "ink": "^7.0.0",
    "ink-spinner": "^5.0.0",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.14",
    "typescript": "^6.0.2"
  }
}
